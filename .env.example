OPENAI_API_KEY=

# Optional hardening overrides — all have sane defaults if unset.
# Sandbox root the file/shell tools are contained to. Defaults to the current
# working directory. Set this to the mounted volume path (e.g. /workspace) when
# running in Docker.
AGENT_WORKDIR=
# Seconds before a shell command run via run_command is killed. Default: 60
AGENT_COMMAND_TIMEOUT_SECONDS=
# Max bytes of stdout/stderr captured per command before truncation. Default: 1000000
AGENT_COMMAND_MAX_OUTPUT_BYTES=
